---
// src/components/Nav.astro
// Shared site navigation. Used by all layouts and pages.
---

<nav class="nav">
  <a href="/">Home</a>
  <a href="/about">About</a>
  <a href="/2026">2026</a>
  <p>avocado</p>
</nav>

<style>
  .nav {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .nav a {
    color: inherit;
    text-decoration: none;
  }

  .nav a:hover {
    opacity: 0.7;
    text-decoration: underline;
    text-underline-offset: 0.18em;
    text-decoration-color: var(--text);
  }

  @media (max-width: 640px) {
    .nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  }
</style>
