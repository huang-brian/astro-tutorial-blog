---
// src/layouts/HomeLayout.astro
// Extends BaseLayout. Adds the two-column header with site title + tagline.

import BaseLayout from './BaseLayout.astro';

export interface Props {
  posts?: {
    id: string;
    data: {
      title: string;
      description?: string;
      excerpt?: string;
      date: Date;
      heroImage?: string;
    };
  }[];
}

const { posts = [] } = Astro.props;

const sortedPosts = [...posts].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Brian Below">

  <style>
    /* ── Nav + site title header ─────────────────────────────── */
    .site-header {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      padding: 3rem 0 2.5rem;
    }

    .nav {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding-top: 0.2rem;
    }

    .nav a {
      font-size: 1rem;
      color: var(--text);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: transparent;
      transition: color 0.2s, text-decoration-color 0.2s;
      opacity: 1;
    }

    .nav a:hover {
      color: var(--text-muted);
      text-decoration-color: var(--text-muted);
      opacity: 1;
    }

    .site-title-block h1 {
      font-size: 3rem;
      font-weight: 500;
      letter-spacing: -0.01em;
      line-height: 1.05;
      margin-bottom: 0.3rem;
    }

    .site-title-block .tagline {
      font-size: 1rem;
      font-style: italic;
      color: var(--text-muted);
    }

    /* ── Posts list ──────────────────────────────────────────── */
    .posts {
      margin-top: 0.5rem;
    }

    .divider {
      height: 1px;
      background: var(--rule);
    }

    .post-link {
      display: block;
      color: inherit;
      /* Override global opacity fade — child elements handle their own transitions */
      opacity: 1;
    }

    .post-row {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      padding: 2rem 0;
      opacity: 0;
      transform: translateY(8px);
      animation: fadeUp 0.45s ease forwards;
    }

    .post-row:nth-child(2)  { animation-delay: 0.04s; }
    .post-row:nth-child(4)  { animation-delay: 0.09s; }
    .post-row:nth-child(6)  { animation-delay: 0.14s; }
    .post-row:nth-child(8)  { animation-delay: 0.19s; }
    .post-row:nth-child(10) { animation-delay: 0.24s; }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    .post-left {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }

    .post-title {
      font-size: 1.3rem;
      font-weight: 500;
      line-height: 1.3;
      transition: color 0.2s;
    }

    .post-link:hover .post-title {
      color: var(--text-muted);
    }

    .post-description {
      font-size: 0.9rem;
      font-style: italic;
      color: var(--text-muted);
      line-height: 1.5;
    }

    .post-right {
      display: flex;
      align-items: flex-start;
    }

    .post-right img {
      width: 100%;
      max-height: 200px;
      object-fit: cover;
      display: block;
      filter: saturate(0.85);
      transition: filter 0.3s;
    }

    .post-link:hover .post-right img {
      filter: saturate(1.05);
    }

    .post-excerpt {
      font-size: 0.9rem;
      font-style: italic;
      color: var(--text-muted);
      line-height: 1.65;
      display: -webkit-box;
      -webkit-line-clamp: 5;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ── Mobile ──────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .site-header {
        grid-template-columns: 1fr;
        gap: 1.25rem;
        padding-top: 2rem;
      }

      .nav { flex-direction: row; flex-wrap: wrap; gap: 0.75rem; }

      .site-title-block h1 { font-size: 2.2rem; }

      .post-row { grid-template-columns: 1fr; }
    }
  </style>

  <!-- ── Header with site title ── -->
  <header class="site-header">
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/2026">2026</a>
    </nav>

    <div class="site-title-block">
      <h1>Brian Below</h1>
      <p class="tagline">musings on life.</p>
    </div>
  </header>

  <!-- ── Post list ── -->
  <section class="posts">
    {sortedPosts.map((post) => (
      <>
        <div class="divider" />
        <a class="post-link" href={`/${post.id.replace(/\.md$/, '')}`}>
          <article class="post-row">
            <div class="post-left">
              <h2 class="post-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="post-description">{post.data.description}</p>
              )}
            </div>

            <div class="post-right">
              {post.data.heroImage ? (
                <img src={post.data.heroImage} alt={post.data.title} />
              ) : (
                <p class="post-excerpt">
                  {post.data.excerpt ?? post.data.description ?? ""}
                </p>
              )}
            </div>
          </article>
        </a>
      </>
    ))}

    <div class="divider" />
  </section>

</BaseLayout>
