---
// src/layouts/HomeLayout.astro
// Extends BaseLayout. Two-column header with site title + tagline, then post list.

import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteTitle from '../components/SiteTitle.astro';

export interface Props {
  posts?: {
    id: string;
    data: {
      title: string;
      description?: string;
      excerpt?: string;
      date: Date;
      heroImage?: string;
    };
  }[];
}

const { posts = [] } = Astro.props;

const sortedPosts = [...posts].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Brian Below">

  <style>
    /* ── Header ──────────────────────────────────────────────── */
    .site-header {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      padding: 3rem 0 0.5rem;
    }

    .nav-col {
      padding-top: 0.2rem;
    }

    /* ── Post list ───────────────────────────────────────────── */
    .posts {
      margin-top: 0.5rem;
    }

    .divider {
      height: 1px;
      background: var(--rule);
    }

    .post-link {
      display: block;
      color: inherit;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .post-link:hover {
      opacity: 0.7;
    }

    .post-row {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      padding: 2rem 0;
      opacity: 0;
      transform: translateY(8px);
      animation: fadeUp 0.45s ease forwards;
    }

    .post-row:nth-child(2)  { animation-delay: 0.04s; }
    .post-row:nth-child(4)  { animation-delay: 0.09s; }
    .post-row:nth-child(6)  { animation-delay: 0.14s; }
    .post-row:nth-child(8)  { animation-delay: 0.19s; }
    .post-row:nth-child(10) { animation-delay: 0.24s; }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    .post-left {
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
      align-self: start;
    }

    .post-title {
      font-size: 1.3rem;
      font-weight: 500;
      line-height: 1.3;
      margin-block: 0;
    }

    .post-description {
      font-size: 0.9rem;
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.4;
    }

    .post-right {
      display: flex;
      align-items: flex-start;
    }

    .post-right img {
      width: 100%;
      max-height: 200px;
      object-fit: cover;
      display: block;
      filter: saturate(0.85);
    }

    .post-excerpt {
      font-family: garamond-premier-pro-display;
      letter-spacing: 0.02em;
      font-size: 0.9rem;
      color: var(--text-muted);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 5;
      -webkit-box-orient: vertical;
      overflow: hidden;
      margin: 0;
    }

    /* ── Mobile ──────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .site-header {
        grid-template-columns: 1fr;
        gap: 1.25rem;
        padding-top: 2rem;
      }

      .post-row { grid-template-columns: 1fr; }
    }
  </style>

  <header class="site-header">
    <div class="nav-col">
      <Nav />
    </div>
    <SiteTitle />
  </header>

  <section class="posts">
    {sortedPosts.map((post) => (
      <>
        <div class="divider" />
        <a class="post-link" href={`/${post.id.replace(/\.md$/, '')}/`}>
          <article class="post-row">
            <div class="post-left">
              <h2 class="post-title">{post.data.title}</h2>
              {post.data.description && (
                <p class="post-description">{post.data.description}</p>
              )}
            </div>

            <div class="post-right">
              {post.data.heroImage ? (
                <img src={post.data.heroImage} alt={post.data.title} />
              ) : (
                <p class="post-excerpt">
                  {post.data.excerpt ?? post.data.description ?? ""}
                </p>
              )}
            </div>
          </article>
        </a>
      </>
    ))}
  </section>

</BaseLayout>
