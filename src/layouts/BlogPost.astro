---
// src/layouts/BlogPost.astro
// Extends BaseLayout. No site title in header — just nav + post header.

import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  date: Date;
  description?: string;
  heroImage?: string;
}

const { title, date, description, heroImage } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Brian Below`} description={description}>

  <style>
    /* ── Minimal nav header — no site title ─────────────────── */
    .site-header {
      display: flex;
      align-items: baseline;
      gap: 2rem;
      padding: 3rem 0 2.5rem;
    }

    .nav {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }

    .nav a {
      font-size: 1rem;
      color: var(--text);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: transparent;
      transition: color 0.2s, text-decoration-color 0.2s;
      opacity: 1; /* use colour shift, not opacity fade */
    }

    .nav a:hover {
      color: var(--text-muted);
      text-decoration-color: var(--text-muted);
      opacity: 1;
    }

    /* ── Post header ─────────────────────────────────────────── */
    .post-header {
      max-width: 70ch;
      margin: 0 auto;            /* centre horizontally */
      padding: 2.5rem 0 1.75rem;
      border-top: 1px solid var(--rule);
    }

    .post-title {
      font-size: 2.2rem;
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.01em;
      margin-bottom: 0.6rem;
    }

    .post-date {
      font-size: 0.9rem;
      font-style: italic;
      color: var(--text-muted);
    }

    /* ── Hero image ──────────────────────────────────────────── */
    .hero {
      max-width: 70ch;
      margin: 0 auto 2rem;       /* centre horizontally */
    }

    .hero img {
      width: 100%;
      display: block;
      filter: saturate(0.9);
    }

    /* ── Prose body ──────────────────────────────────────────── */
    .prose {
      max-width: 70ch;
      margin: 0 auto;            /* centre horizontally — this was the fix */
      padding-bottom: 3rem;
    }

    /* Paragraphs */
    .prose :global(p) {
      margin-bottom: 1.4em;
    }

    /* Headings inside posts */
    .prose :global(h2) {
      font-size: 1.45rem;
      font-weight: 500;
      margin: 2.2em 0 0.6em;
      line-height: 1.25;
    }

    .prose :global(h3) {
      font-size: 1.2rem;
      font-weight: 500;
      margin: 1.8em 0 0.5em;
    }

    /* Blockquotes */
    .prose :global(blockquote) {
      border-left: 2px solid var(--rule);
      margin: 1.8em 0;
      padding: 0.2em 0 0.2em 1.4em;
      color: var(--text-muted);
      font-style: italic;
    }

    /* Inline code */
    .prose :global(code) {
      font-size: 0.88em;
      background: color-mix(in srgb, var(--rule) 30%, transparent);
      padding: 0.1em 0.35em;
    }

    /* Code blocks */
    .prose :global(pre) {
      background: color-mix(in srgb, var(--accent) 10%, var(--bg));
      border: 1px solid var(--rule);
      padding: 1.1em 1.4em;
      overflow-x: auto;
      margin: 1.8em 0;
      font-size: 0.88em;
      line-height: 1.6;
    }

    .prose :global(pre code) {
      background: none;
      padding: 0;
    }

    /* Links inside prose — underline style, not opacity fade */
    .prose :global(a) {
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: var(--rule);
      transition: text-decoration-color 0.2s;
      opacity: 1;
    }

    .prose :global(a:hover) {
      text-decoration-color: var(--text);
      opacity: 1;
    }

    /* Lists */
    .prose :global(ul),
    .prose :global(ol) {
      padding-left: 1.5em;
      margin-bottom: 1.4em;
    }

    .prose :global(li) {
      margin-bottom: 0.4em;
    }

    /* Horizontal rule */
    .prose :global(hr) {
      border: none;
      border-top: 1px solid var(--rule);
      margin: 2.5em 0;
    }

    /* Images inside prose */
    .prose :global(img) {
      max-width: 100%;
      display: block;
      margin: 2em 0;
      filter: saturate(0.9);
    }

    /* ── Mobile ──────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .site-header { padding-top: 2rem; }

      .post-title { font-size: 1.7rem; }

      .nav { flex-direction: row; flex-wrap: wrap; gap: 0.75rem; }
    }
  </style>

  <!-- ── Nav only — no site title ── -->
  <header class="site-header">
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/2026">2026</a>
    </nav>
  </header>

  <!-- ── Post header ── -->
  <div class="post-header">
    <h1 class="post-title">{title}</h1>
    <p class="post-date">{formattedDate}</p>
  </div>

  <!-- ── Optional hero image ── -->
  {heroImage && (
    <div class="hero">
      <img src={heroImage} alt={title} />
    </div>
  )}

  <!-- ── Post body ── -->
  <article class="prose">
    <slot />
  </article>

</BaseLayout>
