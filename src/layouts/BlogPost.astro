---
// src/layouts/BlogPost.astro
// Extends BaseLayout. Renders the nav, post header, optional hero, and prose body.

import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';

export interface Props {
  title: string;
  date: Date;
  description?: string;
  heroImage?: string;
}

const { title, date, description, heroImage } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Brian Below`} description={description}>

  <style>
    /* ── Nav header ──────────────────────────────────────────── */
    .site-header {
      display: flex;
      align-items: baseline;
      gap: 2rem;
      padding: 3rem 0 2.5rem;
    }

    /* ── Post header ─────────────────────────────────────────── */
    .post-header {
      max-width: 70ch;
      margin: 0 auto;
      padding: 2.5rem 0 1.75rem;
      border-top: 1px solid var(--rule);
    }

    .post-title {
      font-size: 2.2rem;
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.01em;
      margin-bottom: 0.6rem;
    }

    .post-date {
      font-size: 0.9rem;
      font-family: garamond-premier-pro-caption;
      color: var(--text-muted);
    }

    /* ── Hero image ──────────────────────────────────────────── */
    .hero {
      max-width: 70ch;
      margin: 0 auto 2rem;
    }

    .hero img {
      width: 100%;
      display: block;
      filter: saturate(0.9);
    }

    /* ── Prose body ──────────────────────────────────────────── */
    .prose {
      max-width: 70ch;
      margin: 0 auto;
      padding-bottom: 3rem;
    }

    .prose :global(p)  { margin-bottom: 1em; }

    .prose :global(h2) {
      font-size: 1.45rem;
      font-weight: 500;
      margin: 2.2em 0 0.6em;
      line-height: 1.25;
    }

    .prose :global(h3) {
      font-size: 1.2rem;
      font-weight: 500;
      margin: 1.8em 0 0.5em;
    }

    .prose :global(blockquote) {
      border-left: 2px solid var(--rule);
      margin: 1.8em 0;
      padding: 0.2em 0 0.2em 1.4em;
      color: var(--text-muted);
      font-style: italic;
    }

    .prose :global(code) {
      font-size: 0.88em;
      background: color-mix(in srgb, var(--rule) 30%, transparent);
      padding: 0.1em 0.35em;
    }

    .prose :global(pre) {
      background: color-mix(in srgb, var(--text) 10%, var(--bg));
      border: 1px solid var(--rule);
      padding: 1.1em 1.4em;
      overflow-x: auto;
      margin: 1.8em 0;
      font-size: 0.88em;
      line-height: 1.6;
    }

    .prose :global(pre code) {
      background: none;
      padding: 0;
    }

    /* Needs :global() to reach markdown-rendered anchor tags */
    .prose :global(a) {
      text-decoration: underline;
      text-underline-offset: 0.18em;
      text-decoration-color: var(--rule);
      color: inherit;
      transition: opacity 0.2s;
    }

    .prose :global(a:hover) { opacity: 0.7; }

    .prose :global(ul),
    .prose :global(ol) {
      padding-left: 1.5em;
      margin-bottom: 1.4em;
    }

    .prose :global(li)  { margin-bottom: 0.4em; }

    .prose :global(hr) {
      border: none;
      border-top: 1px solid var(--rule);
      margin: 2.5em 0;
    }

    .prose :global(img) {
      max-width: 100%;
      display: block;
      margin: 2em 0;
      filter: saturate(0.9);
    }

    /* ── Mobile ──────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .site-header  { padding-top: 2rem; }
      .post-title   { font-size: 1.7rem; }
    }
  </style>

  <header class="site-header">
    <Nav />
  </header>

  <div class="post-header">
    <h1 class="post-title">{title}</h1>
    <p class="post-date">{formattedDate}</p>
  </div>

  {heroImage && (
    <div class="hero">
      <img src={heroImage} alt={title} />
    </div>
  )}

  <article class="prose">
    <slot />
  </article>

</BaseLayout>
