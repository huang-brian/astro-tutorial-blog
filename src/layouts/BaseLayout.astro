---
// src/layouts/BaseLayout.astro
// The root layout that all other layouts extend.
// Provides: favicon, fonts, global tokens, link styles, footer.

export interface Props {
  title?: string;
  description?: string;
}

const { title = "Brian Below", description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Favicon -->
    <link rel="icon" href="/favicon.png" type="image/png" />

    <!-- Typekit fonts -->
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/egh3idp.css" />

    <style>
      /* ── Design tokens ───────────────────────────────────── */
      :root {
        --bg:         #EFE6EB;
        --text:       #380D25;
        --text-muted: #6b4057;
        --accent:     #380D25;
        --rule:       #c9aab9;
        --font:       adobe-garamond-pro, garamond-premier-pro-display, Georgia, serif;
        --max-width:  860px;
        --h-pad:      3rem;
        --link-fade:  0.2s ease;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg:         #380D25;
          --text:       #f0e2ea;
          --text-muted: #c9a0b8;
          --accent:     #EFE6EB;
          --rule:       #5e2040;
        }
      }

      /* ── Reset ───────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        font-feature-settings: "liga" 1;
        font-size: 18px;
        line-height: 1.6;
        transition: background 0.3s ease, color 0.3s ease;
      }

      /* ── Global link reset — no ugly browser blue ────────── */
      a {
        color: inherit;
        text-decoration: none;
      }

      /* ── Universal hover fade on all clickable elements ──── */
      a,
      button,
      [role="button"],
      summary {
        transition: opacity var(--link-fade);
      }

      a:hover,
      button:hover,
      [role="button"]:hover,
      summary:hover {
        opacity: 0.65;
      }

      /*
        Layouts that want richer hover effects (e.g. color shifts)
        should set `transition` on child elements and override the
        opacity rule with `opacity: 1` on the parent :hover if needed.
      */

      /* ── Page wrapper ────────────────────────────────────── */
      .page {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 var(--h-pad);
      }

      /* ── Footer ──────────────────────────────────────────── */
      .site-footer {
        margin-top: 3rem;
        padding: 2rem 0 3rem;
        border-top: 1px solid var(--rule);
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 1rem;
        font-size: 0.875rem;
        color: var(--text-muted);
      }

      .footer-left  { text-align: left; }
      .footer-mid   { text-align: center; }
      .footer-right { text-align: right; }

      .footer-left .name {
        font-weight: 500;
        color: var(--text);
        display: block;
        margin-bottom: 0.2rem;
      }

      /* Override the global fade for footer email link — use color instead */
      .footer-left a {
        color: var(--text-muted);
        transition: color 0.2s;
        opacity: 1; /* prevent double fade */
      }
      .footer-left a:hover {
        color: var(--text);
        opacity: 1;
      }

      .subscribe-btn {
        display: inline-block;
        padding: 0.4rem 1.25rem;
        border: 1px solid var(--text);
        border-radius: 0;
        color: var(--text);
        background: transparent;
        font-family: var(--font);
        font-size: 0.95rem;
        cursor: pointer;
        margin-bottom: 0.4rem;
        transition: background 0.2s, color 0.2s, border-color 0.2s;
        /* Override global opacity fade — colour invert is richer */
        opacity: 1;
      }

      .subscribe-btn:hover {
        background: var(--accent);
        color: var(--bg);
        border-color: var(--accent);
        opacity: 1;
      }

      .subscribe-note {
        display: block;
        font-size: 0.8rem;
        font-style: italic;
      }

      /* ── Mobile ──────────────────────────────────────────── */
      @media (max-width: 640px) {
        :root { --h-pad: 1.25rem; }

        .site-footer {
          grid-template-columns: 1fr;
          gap: 1.5rem;
        }

        .footer-mid,
        .footer-right { text-align: left; }
      }
    </style>
  </head>

  <body>
    <div class="page">

      <!-- Page-specific header/content injected here -->
      <slot />

      <!-- Shared footer -->
      <footer class="site-footer">
        <div class="footer-left">
          <span class="name">Brian Below</span>
          Say hi: <a href="mailto:hey@brianbelow.net">hey@brianbelow.net</a>
        </div>

        <div class="footer-mid">
          <button class="subscribe-btn">Subscribe</button>
          <span class="subscribe-note">Receive new posts in your email.</span>
        </div>

        <div class="footer-right">
          <span>Hosted on <a href="https://www.netlify.com/">Netlify</a><br>
            Built with <a href="https://astro.build/">Astro</a> + Claude<br>
            Published in Santa Cruz, California</span>
          
        </div>
      </footer>

    </div><!-- /.page -->
  </body>
</html>
