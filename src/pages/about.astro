---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="About — Brian Below">
  <style>
    .site-header {
      padding: 3rem 0 2.5rem;
    }

    .content {
      max-width: 70ch;
      margin: 0 auto;
      border-top: 1px solid var(--rule);
      padding-top: 2.5rem;
      padding-bottom: 3rem;
    }

    h1 {
      font-size: 2.2rem;
      font-weight: 500;
      margin-bottom: 1.2rem;
    }

    p { margin-bottom: 1.4em; }

    @media (max-width: 640px) {
      .site-header { padding-top: 2rem; }
    }
  </style>

  <header class="site-header">
    <Nav />
  </header>

  <div class="content">
    <h1>About Brian</h1>
    <p>Hello, this is some text.</p>
    <p>This is some more text about Brian. On another p element!</p>
  </div>
</BaseLayout>
