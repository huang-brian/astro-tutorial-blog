---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    title: "The Weight of Silence",
    description: "An exploration of the quiet moments between the noise of modern life.",
    image: "https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&fit=crop&q=80&w=1000",
    imageSide: "left"
  },
  {
    title: "Santa Cruz Fog",
    description: "The way the mist rolls off the Pacific and settles into the redwoods.",
    image: "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&q=80&w=1000",
    imageSide: "right"
  },
  {
    title: "Digital Ephemera",
    description: "Why we write in a world that only wants to skim.",
    excerpt: "This is a short excerpt from the blog post that fills the space where an image might usually sit, maintaining the rhythm of the page when visual media is absent...",
    image: null
  }
];
---

<Layout title="Brian Below | Musings on Life">
  <div class="container">
    
    <header class="site-header">
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/2026">2026</a>
      </nav>
      
      <div class="header-content">
        <h1 class="site-title">Brian Below</h1>
        <p class="site-tagline">musings on life.</p>
        <p class="site-description">A short description of the blog here to set the tone for the reader.</p>
      </div>
    </header>

    <main class="feed">
      {posts.map((post) => (
        <article class="post-entry">
          <hr />
          <div class="post-grid">
            <div class="post-info">
              <h2 class="post-title">{post.title}</h2>
              <p class="post-desc">{post.description}</p>
            </div>
            
            <div class="post-media">
              {post.image ? (
                <div class="aspect-ratio-box">
                  <img src={post.image} alt={post.title} class="post-image" />
                </div>
              ) : (
                <div class="excerpt-container">
                  <p class="post-excerpt">{post.excerpt}</p>
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
      <hr />
    </main>

    <footer class="site-footer">
      <div class="footer-col">
        <p><strong>Brian Below</strong></p>
        <p>Say hi: <a href="mailto:hey@brianbelow.net">hey@brianbelow.net</a></p>
        <p>Built with <a href="https://astro.build">Astro</a></p>
      </div>
      <div class="footer-col center">
        <button class="subscribe-btn">Subscribe</button>
        <p>Receive new posts in your email.</p>
      </div>
      <div class="footer-col right">
        <p>Published in Santa Cruz, California</p>
        <p>Hosted on _____</p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  /* Header & Grid Layout */
  .site-header, .post-grid {
    display: grid;
    grid-template-columns: 1fr 2fr; /* 1/3 to 2/3 ratio  */
    gap: 3rem;
    align-items: start;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 1.1rem;
    padding-top: 0.5rem; /* Aligns with Title baseline */
  }

  .site-title {
    font-size: 3.5rem;
    line-height: 0.9;
    margin-bottom: 0.5rem;
  }

  .site-tagline {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .site-description {
    font-style: italic;
    max-width: 500px;
    opacity: 0.8;
  }

  /* Post Styles */
  .post-entry {
    margin-top: 2rem;
  }

  .post-title {
    font-size: 1.6rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .post-desc {
    font-size: 1rem;
    line-height: 1.5;
    opacity: 0.9;
  }

  .aspect-ratio-box {
    width: 100%;
    aspect-ratio: 3 / 2; /* Landscape [cite: 5, 6] */
    overflow: hidden;
    background: rgba(0,0,0,0.05);
  }

  .post-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-excerpt {
    font-style: italic;
    line-height: 1.7;
    font-size: 1.1rem;
    padding: 1rem 0;
  }

  /* Footer */
  .site-footer {
    margin-top: 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  
  .center { text-align: center; }
  .right { text-align: right; }

  .subscribe-btn {
    background: var(--text-color);
    color: var(--bg-color);
    border: none;
    padding: 0.6rem 1.8rem;
    font-family: inherit;
    cursor: pointer;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Mobile Adjustments */
  @media (max-width: 768px) {
    .container { padding: 2rem 1.5rem; }

    .site-header {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .nav-links {
      flex-direction: row; /* Horizontal bar for mobile */
      gap: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 1rem;
      margin-bottom: 0;
    }

    .post-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .site-footer {
      grid-template-columns: 1fr;
      text-align: left;
    }
    
    .center, .right { text-align: left; }
    
    .site-title { font-size: 2.5rem; }
  }
</style>