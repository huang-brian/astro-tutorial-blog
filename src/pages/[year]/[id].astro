---
// claude convo https://claude.ai/chat/3c6d8574-f947-4cdd-b4cb-2ced9884b726
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => {
    const year = post.data.date.getFullYear().toString();
    // In Astro v6, id includes the path: "2026/my-first-post"
    // We derive the slug by removing the year folder prefix
    const slug = post.id.replace(/^\d{4}\//, '');

    // check for folder year mismatch
    // throw warn if mismatch found
    const folderYear = post.id.split('/')[0];
    const dataYear = post.data.date.getFullYear().toString();
    if (folderYear !== dataYear) {
      console.warn(`Year mismatch in ${post.id}`);
    }

    return {
      params: { year, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BlogPost title={post.data.title} date={post.data.date} description={post.data.description} heroImage={post.data.heroImage}>
  <Content />
</BlogPost>