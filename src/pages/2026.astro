---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteTitle from '../components/SiteTitle.astro';

const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true && new Date(data.date).getFullYear() === 2026;
});

const sortedPosts = [...allPosts].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="2026 — Brian Below">
  <style>
    .site-header {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      padding: 3rem 0 1rem;
      border-bottom: 1px solid var(--rule);
    }

    .nav-col {
      padding-top: 0.2rem;
    }

    .content {
      padding-top: 1.5rem;
      padding-bottom: 1.5rem;
    }

    h1 {
      font-size: 2.2rem;
      font-weight: 500;
      margin-bottom: 1.5rem;
    }

    .post-list {
      list-style: none;
      padding: 0;
    }

    .post-list li {
      border-top: 1px solid var(--rule);
    }

    .post-list a {
      display: block;
      padding: 0.85rem 0;
      text-decoration: none;
      color: inherit;
      transition: opacity 0.2s;
    }

    .post-list a:hover { opacity: 0.7; }

    .post-title {
      font-size: 1.1rem;
      font-weight: 500;
      margin: 0;
    }

    .post-date {
      font-size: 0.875rem;
      color: var(--text-muted);
      font-style: italic;
      margin: 0.15rem 0 0;
    }

    @media (max-width: 640px) {
      .site-header {
        grid-template-columns: 1fr;
        gap: 1.25rem;
        padding-top: 2rem;
      }
    }
  </style>

  <header class="site-header">
    <div class="nav-col">
      <Nav />
    </div>
    <SiteTitle />
  </header>

  <div class="content">
    <h1>2026</h1>
    <ul class="post-list">
      {sortedPosts.map((post) => (
        <li>
          <a href={`/${post.id.replace(/\.md$/, '')}/`}>
            <p class="post-title">{post.data.title}</p>
            <p class="post-date">
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
