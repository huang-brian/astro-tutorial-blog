---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import SiteTitle from '../components/SiteTitle.astro';
---

<BaseLayout title="404 — Brian Below">
  <style>
    .site-header {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      padding: 3rem 0 1rem;
    }

    .nav-col {
      padding-top: 0.2rem;
    }

    .divider {
      height: 1px;
      background: var(--rule);
    }

    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 1em;
      margin: 2.5em;
    }

    h2 {
      font-size: 4.5rem;
      font-weight: 200;
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--text-muted);
      margin-block: 0;
    }

    @media (max-width: 640px) {
      .site-header {
        grid-template-columns: 1fr;
        gap: 1.25rem;
        padding-top: 2rem;
      }
    }
  </style>

  <header class="site-header">
    <div class="nav-col">
      <Nav />
    </div>
    <SiteTitle />
  </header>

  <div class="divider"></div>

  <div class="container">
    <h2>404.</h2>
    <p>Page not found.<br />
    This page doesn't exist yet :(</p>
  </div>
</BaseLayout>
