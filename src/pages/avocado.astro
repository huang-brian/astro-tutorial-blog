---
// src/pages/avocado.astro
import ExtendedBase from "../layouts/ExtendedBase.astro";

const images = Object.keys(import.meta.glob("/public/avocado/*.jpeg")).map(
  (path) => path.replace("/public", "")
);
---

<ExtendedBase title="Avocado">
  <img
    id="avo"
    src=""
    alt="avocado"
    style="cursor: pointer; max-width: 100%; display: block; margin-top: 2rem;"
    title="avocado"
  />
</ExtendedBase>

<script define:vars={{ images }}>
  const img = document.getElementById("avo");
  let currentIndex = Math.floor(Math.random() * images.length);

  function nextIndex() {
    let next;
    do { next = Math.floor(Math.random() * images.length); }
    while (next === currentIndex);
    return next;
  }

  img.src = images[currentIndex];

  img.addEventListener("click", () => {
    currentIndex = nextIndex();
    img.src = images[currentIndex];
  });
</script>